{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "resolveJsonModule": true,
    "types": [
      "jest"
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "tailwind.config": [
        "./tailwind.config.js"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "nativewind-env.d.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods",
    "src/components/ui/*/**/*.ts",
    "src/components/ui/*/**/*.tsx",
    "src/components/ui/gluestack-ui-provider/index.web.tsx",
    "src/components/ui/gluestack-ui-provider/script.ts"
  ]
}
