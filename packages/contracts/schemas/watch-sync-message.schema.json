{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.dive-app.local/watch-sync-message.schema.json",
  "title": "WatchSyncMessage",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "sessionCreated",
        "sessionUpdated",
        "sessionEnded"
      ]
    },
    "session": {
      "$ref": "./watch-session.schema.json"
    }
  },
  "required": [
    "type",
    "session"
  ]
}
